// -*- mode: jsonc -*-
{
  "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  // "height": 28, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 4, // Gaps between modules (4px)
  "margin-top": 6,
  "margin-left": 6,
  "margin-right": 6,
  // Choose the order of the modules
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "group/hidden"
    //"hyprland/window"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "pulseaudio",
    //"network",
    "backlight",
    "battery",
    "tray",
    "custom/notification",
    "custom/power",
    ],

  // Modules configuration

  "custom/launcher":{
    "format" : "пЊѓ",                                  //пЊѓ
    "tooltip-format": "App Menu",
    "on-click":"pkill rofi || rofi -show drun",
    "on-click-right":"hyprctl dispatch overview:toggle",
    "escape": true,
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      //"1": "п„ ",
      //"2": "п‰Ё",
      //"3": "п„Ў",
      //"4": "п†ј",
      //"5": "пЃµ",
      //"active": "п†’",
      //"default": "п„‘ "
    },

    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "all-outputs": false,
    "persistent-workspaces": {
    "*": 5,
    }
  },

  "group/hidden": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 300,
        "click-to-reveal": false,
        "children-class": "not-power",
        "transition-left-to-right": true,
    },

    "modules": [
        "custom/expand",
        "custom/settings", // First element is the "group leader" and won't ever be hidden
        "custom/github",
        "custom/chatgpt",
    ]
  },

  "custom/expand": {
    "format": "пЃ”",
    "tooltip-format": "Show More"
  },

  "custom/settings": {
    "format": "пЂ“",
    "on-click": "hyprgui",
    "tooltip-format": "Settings"
  },

  "custom/github": {
    "format": "п‚›",
    "on-click": "chromium --incognito --app=https://www.github.com/login",
    "tooltip-format": "Github"
  },

  "custom/chatgpt": {
    "format": "пЃ™",
    "on-click": "chromium --incognito --app=https://chat.openai.com",
    "tooltip-format": "ChatGPT"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 10,
  },

  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%d-%m-%y}</big>\n<tt><big>{calendar}</big></tt>",
    "format-alt": "{:%d-%m-%Y}"
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "scroll-step": 5,
    "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
    "tooltip-format": "Brightness"
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 20,
      "critical": 10
    },

    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% у°‚„",
    "format-plugged": "{capacity}% у°‚„",
    "format-alt": "{time} {icon}",
    "format-critical": "{capacity}% у°‚ѓ",
    //"format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
    "interval": 1
  },

  "network": {
    "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{essid} ({signalStrength}%) п‡«",
    "format-ethernet": "{ipaddr}/{cidr} пћ–",
    "tooltip-format": "{ifname} via {gwaddr} пћ–",
    "format-linked": "{ifname} (No IP) пћ–",
    "format-disconnected": "Disconnected вљ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "pulseaudio": {
    "tooltip-format": "Volume Control",
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "о»Ё  Muted",
    "on-click":"wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right":"pkill pavucontrol || pavucontrol",
    "format-icons": {
    "default": ["пЂ¦", "пЂ§", "пЂЁ "],
    }
  },
  
  "custom/power": {
    "format" : "пЂ‘",
    "tooltip-format": "Power Menu",
    "on-click":"wlogout",
  },

  "custom/notification": {
    "tooltip-format": "Notifications",
    "format": "{icon}",
    "format-icons": {
      "notification": "о®љ",
      "none": "оЄў",
      "dnd-notification": "о°‰",
      "dnd-none": "о°€",
      "inhibited-notification": "о®љ",
      "inhibited-none": "оЄў",
      "dnd-inhibited-notification": "о°‰",
      "dnd-inhibited-none": "о°€"
    },

    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
}
