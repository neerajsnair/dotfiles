// -*- mode: jsonc -*-
{
  "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  // "height": 28, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 4, // Gaps between modules (4px)
  "margin-top": 6,
  "margin-left": 6,
  "margin-right": 6,
  // Choose the order of the modules
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "group/hidden"
    //"hyprland/window"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "pulseaudio",
    //"network",
    "backlight",
    "battery",
    "tray",
    "custom/notification",
    "custom/power",
    ],

  // Modules configuration

  "custom/launcher":{
    "format" : "´îâ",                                  //´îâ
    "tooltip-format": "App Menu",
    "on-click":"pkill rofi || rofi -show drun",
    "on-click-right":"hyprctl dispatch overview:toggle",
    "escape": true,
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      //"1": "´äá",
      //"2": "´ë¿",
      //"3": "´äí",
      //"4": "´å╝",
      //"5": "´üÁ",
      //"active": "´åÆ",
      //"default": "´äæ "
    },

    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "all-outputs": false,
    "persistent-workspaces": {
    "*": 5,
    }
  },

  "group/hidden": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 300,
        "click-to-reveal": false,
        "children-class": "not-power",
        "transition-left-to-right": true,
    },

    "modules": [
        "custom/expand",
        "custom/settings", // First element is the "group leader" and won't ever be hidden
        "custom/github",
        "custom/chatgpt",
    ]
  },

  "custom/expand": {
    "format": "´üö",
    "tooltip-format": "Show More"
  },

  "custom/settings": {
    "format": "´Çô",
    "on-click": "hyprgui",
    "tooltip-format": "Settings"
  },

  "custom/github": {
    "format": "´éø",
    "on-click": "chromium --incognito --app=https://www.github.com/login",
    "tooltip-format": "Github"
  },

  "custom/chatgpt": {
    "format": "´üÖ",
    "on-click": "chromium --incognito --app=https://chat.openai.com",
    "tooltip-format": "ChatGPT"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 10,
  },

  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%d-%m-%y}</big>\n<tt><big>{calendar}</big></tt>",
    "format-alt": "{:%d-%m-%Y}"
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "scroll-step": 5,
    "format-icons": ["¯Äı", "¯Åô", "¯Åæ", "¯ÅÅ", "¯ÅÄ", "¯Åı", "¯Åè", "¯Åê", "¯Äø"],
    "tooltip-format": "Brightness"
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 20,
      "critical": 10
    },

    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% ¾░éä",
    "format-plugged": "{capacity}% ¾░éä",
    "format-alt": "{time} {icon}",
    "format-critical": "{capacity}% ¾░éâ",
    //"format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
    "interval": 1
  },

  "network": {
    "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{essid} ({signalStrength}%) ´ç½",
    "format-ethernet": "{ipaddr}/{cidr} ´Şû",
    "tooltip-format": "{ifname} via {gwaddr} ´Şû",
    "format-linked": "{ifname} (No IP) ´Şû",
    "format-disconnected": "Disconnected ÔÜá",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "pulseaudio": {
    "tooltip-format": "Volume Control",
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "¯╗¿  Muted",
    "on-click":"wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right":"pkill pavucontrol || pavucontrol",
    "format-icons": {
    "default": ["´ÇĞ", "´Çğ", "´Ç¿"],
    }
  },
  
  "custom/power": {
    "format" : "´Çæ",
    "tooltip-format": "Power Menu",
    "on-click":"wlogout",
  },

  "custom/notification": {
    "tooltip-format": "Notifications",
    "format": "{icon}",
    "format-icons": {
      "notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "none": "´éó",
      "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-none": "´çÀ",
      "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-inhibited-none": "´çÀ"
    },

    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
}
