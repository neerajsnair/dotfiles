// -*- mode: jsonc -*-
{
  "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  // "height": 28, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 4, // Gaps between modules (4px)
  "margin-top": 2,
  "margin-left": 2,
  "margin-right": 2,
  // Choose the order of the modules
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "wlr/taskbar"
    //"group/hidden"
    //"hyprland/window"
  ],

  "modules-center": [
    "clock"
    //"hyprland/workspaces"
  ],

  "modules-right": [
    //"clock",
    "idle_inhibitor",
    "pulseaudio",
    //"network",
    "backlight",
    "battery",
    "tray",
    "custom/notification",
    "custom/power",
    ],

  // Modules configuration

  "custom/launcher":{
    "format" : "",                                  //
    "tooltip-format": "App Menu",
    "on-click":"pkill rofi || rofi -show drun",
    "on-click-right":"hyprctl dispatch overview:toggle",
    "escape": true,
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "rotate": 0,
    "icon-size": 16,
    "icon-theme": "Papirus-Dark",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    //"ignore-list": [
    //  "Alacritty"
    //],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      //"1": "",
      //"2": "",
      //"3": "",
      //"4": "",
      //"5": "",
      //"active": "",
      //"default": " "
    },

    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "all-outputs": false,
    "persistent-workspaces": {
    "*": 5,
    }
  },

  "group/hidden": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 300,
        "click-to-reveal": false,
        "children-class": "not-power",
        "transition-left-to-right": true,
    },

    "modules": [
        "custom/expand",
        "custom/settings", // First element is the "group leader" and won't ever be hidden
        "custom/github",
        "custom/chatgpt",
    ]
  },

  "custom/expand": {
    "format": "",
    "tooltip-format": "Show More"
  },

  "custom/settings": {
    "format": "",
    "on-click": "hyprgui",
    "tooltip-format": "Settings"
  },

  "custom/github": {
    "format": "",
    "on-click": "chromium --incognito --app=https://www.github.com/login",
    "tooltip-format": "Github"
  },

  "custom/chatgpt": {
    "format": "",
    "on-click": "chromium --ozone-platform=wayland --incognito --app=https://chat.openai.com",
    "tooltip-format": "ChatGPT"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 10,
  },

  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%d-%m-%y}</big>\n<tt><big>{calendar}</big></tt>",
    "format-alt": "{:%d-%m-%Y}"
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "scroll-step": 5,
    "format-icons": ["", "", "", "", "", "", "", "", ""],
    "tooltip-format": "Brightness"
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 20,
      "critical": 10
    },

    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% 󰂄",
    "format-plugged": "{capacity}% 󰂄",
    "format-alt": "{time} {icon}",
    "format-critical": "{capacity}% 󰂃",
    //"format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "interval": 1
  },

  "network": {
    "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{essid} ({signalStrength}%) ",
    "format-ethernet": "{ipaddr}/{cidr} ",
    "tooltip-format": "{ifname} via {gwaddr} ",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "Disconnected ⚠",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "pulseaudio": {
    "tooltip-format": "Volume Control",
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "  Muted",
    "on-click":"wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right":"pkill pavucontrol || pavucontrol",
    "format-icons": {
    "default": ["", "", " "],
    }
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    }
  },
  
  "custom/power": {
    "format" : "",
    "tooltip-format": "Power Menu",
    "on-click":"wlogout",
  },

  "custom/notification": {
    "tooltip-format": "Notifications",
    "format": "{icon}",
    "format-icons": {
      "notification": "",
      "none": "",
      "dnd-notification": "",
      "dnd-none": "",
      "inhibited-notification": "",
      "inhibited-none": "",
      "dnd-inhibited-notification": "",
      "dnd-inhibited-none": ""
    },

    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
}
