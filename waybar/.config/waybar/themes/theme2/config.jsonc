// -*- mode: jsonc -*-
{
  "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  // "height": 28, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 4, // Gaps between modules (4px)
  "margin-top": 2,
  "margin-left": 2,
  "margin-right": 2,
  // Choose the order of the modules
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "wlr/taskbar"
    //"group/hidden"
    //"hyprland/window"
  ],

  "modules-center": [
    "clock"
    //"hyprland/workspaces"
  ],

  "modules-right": [
    //"clock",
    "idle_inhibitor",
    "pulseaudio",
    //"network",
    "backlight",
    "battery",
    "power-profiles-daemon",
    "tray",
    "custom/notification",
    "custom/power",
    ],

  // Modules configuration

  "custom/launcher":{
    "format" : "ο¨É",                                  //ο¨É
    "tooltip-format": "App Menu",
    "on-click":"pkill rofi || rofi -show drun",
    "on-click-right":"hyprctl dispatch overview:toggle",
    "escape": true,
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "rotate": 0,
    "icon-size": 16,
    "icon-theme": "Papirus-Dark",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
        "blueman-manager"
    //  "Alacritty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      //"1": "ο³†",
      //"2": "οâ®",
      //"3": "ο³Γ",
      //"4": "οÜΦ",
      //"5": "ο¹Β",
      //"active": "οÜ£",
      //"default": "ο³ë "
    },

    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "all-outputs": false,
    "persistent-workspaces": {
    "*": 5,
    }
  },

  "group/hidden": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 300,
        "click-to-reveal": false,
        "children-class": "not-power",
        "transition-left-to-right": true,
    },

    "modules": [
        "custom/expand",
        "custom/settings", // First element is the "group leader" and won't ever be hidden
        "custom/github",
        "custom/chatgpt",
    ]
  },

  "custom/expand": {
    "format": "ο¹î",
    "tooltip-format": "Show More"
  },

  "custom/settings": {
    "format": "οÄ™",
    "on-click": "hyprgui",
    "tooltip-format": "Settings"
  },

  "custom/github": {
    "format": "ο²¦",
    "on-click": "chromium --incognito --app=https://www.github.com/login",
    "tooltip-format": "Github"
  },

  "custom/chatgpt": {
    "format": "ο¹ô",
    "on-click": "chromium --ozone-platform=wayland --incognito --app=https://chat.openai.com",
    "tooltip-format": "ChatGPT"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 10,
  },

  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%d-%m-%y}</big>\n<tt><big>{calendar}</big></tt>",
    "format-alt": "{:%d-%m-%Y}"
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "scroll-step": 5,
    "format-icons": ["νéç", "νè™", "νèë", "νèè", "νèé", "νèç", "νèä", "νèà", "νé¦"],
    "tooltip-format": "Brightness"
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 20,
      "critical": 10
    },

    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% σΑ²³",
    "format-plugged": "{capacity}% σΑ²³",
    "format-alt": "{time} {icon}",
    "format-critical": "{capacity}% σΑ²É",
    //"format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "interval": 1
  },

  "network": {
    "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{essid} ({signalStrength}%) ο΅Ϊ",
    "format-ethernet": "{ipaddr}/{cidr} οû•",
    "tooltip-format": "{ifname} via {gwaddr} οû•",
    "format-linked": "{ifname} (No IP) οû•",
    "format-disconnected": "Disconnected βö†",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "pulseaudio": {
    "tooltip-format": "Volume Control",
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "νΜ®  Muted",
    "on-click":"wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right":"pkill pavucontrol || pavucontrol",
    "format-icons": {
    "default": ["οÄΠ", "οÄß", "οÄ® "],
    }
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ο¹°",
      "deactivated": "ο¹Α"
    }
  },
  
  "custom/power": {
    "format" : "οÄë",
    "tooltip-format": "Power Menu",
    "on-click":"wlogout",
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "οÉß",
      "performance": "οÉß",
      "balanced": "οâé ",
      "power-saver": "ο¹§ "
    }
  },

  "custom/notification": {
    "tooltip-format": "Notifications",
    "format": "{icon}",
    "format-icons": {
      "notification": "ν°ö",
      "none": "νΣΔ",
      "dnd-notification": "νΑâ",
      "dnd-none": "νΑà",
      "inhibited-notification": "ν°ö",
      "inhibited-none": "νΣΔ",
      "dnd-inhibited-notification": "νΑâ",
      "dnd-inhibited-none": "νΑà"
    },

    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
}
