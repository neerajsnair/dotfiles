
#SHELL
    command = /bin/fish
    shell-integration = fish

#FONT
    font-family = MesloLGS Nerd Font Mono
    font-size = 13

#THEME & COLORS
    theme = Dracula
    #background = #020819
    #background-opacity = 0.7

#WINDOW
    window-decoration = false
    window-theme = ghostty
    gtk-wide-tabs = false
    adw-toolbar-style = flat
    confirm-close-surface = false

#KEYBINDINGS

    keybind = alt+t=toggle_window_decorations

    #SPLITS
    keybind = alt+h=new_split:left
    keybind = alt+l=new_split:right
    keybind = alt+k=new_split:up
    keybind = alt+j=new_split:down
